# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# generated media
public/audio/*
public/renders/*
public/videos/*
public/uploads/*
!public/audio/.gitkeep
!public/renders/.gitkeep
!public/videos/.gitkeep
!public/uploads/.gitkeep

# database
*.db
*.db-journal
prisma/dev.db
prisma/dev.db-journal

# render data
/data

# electron
/dist-electron

# remotion bundle cache
/.remotion-bundle
